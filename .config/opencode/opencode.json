{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": [
    "cloudflare-ai-gateway"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "qwen/qwen3.5-9b": {
          "name": "Qwen 3.5 9B"
        },
        "google/gemma-4-e4b": {
          "name": "Gemma 4 E4B"
        },
        "openai/gpt-oss-20b": {
          "name": "GPT OSS 20B"
        },
      }
    },
    "framework": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Framework Desktop",
      "options": {
        "baseURL": "http://framework.home.lan:8080/v1"
      },
      "models": {
        "Qwen3.6-27B-Q4_K_M": {
          "name": "Qwen 3.6 27B"
        },
        "Qwen3.6-35B-A3B-MXFP4_MOE": {
          "name": "Qwen 3.6 35B A3B (MOE)"
        },
        "Qwen3.6-35B-A3B-UD-Q4_K_M": {
          "name": "Qwen 3.6 35B A3B"
        },
        "gpt-oss-120b-F16": {
          "name": "GPT OSS 120B"
        },
      }
    },
    "yescale": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "YEScale",
      "options": {
        "baseURL": "https://api.yescale.vip/v1",
      },
      "models": {
        "gemini-3-pro-preview": {
          "name": "Gemini 3 Pro"
        },
        "gemini-3-flash-preview": {
          "name": "Gemini 3 Flash"
        },
        "deepseek-v3.2-thinking": {
          "name": "Deepseek v3.2"
        },
        "MiniMax-M2.7": {
          "name": "MiniMax M2.7"
        },
      }
    }
  },
  "permission": {
    "*": "ask",
    "task": {
      "*": "ask",
      "knowledge-base": "allow",
      "research": "allow",
    },
    "read": {
      "*": "ask",
      "~/Repo/*": "allow"
    },
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "find *": "allow",
      "find * -exec *": "deny",
      "git status *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "echo *": "allow",
      "wc *": "allow",
      "ls *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "tree *": "allow",
      "file *": "allow",
    },
    "external_directory": {
      "*": "ask",
      "~/Repo/*": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "skill": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "kubernetes_pods_list_*": "allow",
    "kubernetes_pods_get": "allow",
    "kubernetes_pods_log": "allow",
    "kubernetes_resources_list": "allow",
    "kubernetes_resources_get": "allow",
    "kubernetes_namespaces_list": "allow",
    "kubernetes_configuration_contexts_list": "allow",
    "excalidraw_*": "allow",
  },
  "mcp": {
    "kubernetes": {
      "type": "local",
      "command": [
        "uvx",
        "kubernetes-mcp-server@latest",
        "--read-only"
      ],
      "enabled": false,
      "environment": {}
    },
    "excalidraw": {
      "type": "remote",
      "url": "https://mcp.excalidraw.com",
      "enabled": false
    },
  }
}
