{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": [
    "cloudflare-ai-gateway"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "qwen/qwen3.5-9b": {
          "name": "Qwen 3.5 9B"
        },
        "google/gemma-4-e4b": {
          "name": "Gemma 4 E4B"
        },
        "openai/gpt-oss-20b": {
          "name": "GPT OSS 20B"
        },
      }
    },
    "framework": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Framework Desktop",
      "options": {
        "baseURL": "http://framework.home.lan:8080/v1"
      },
      "models": {
        "Qwen3.6-27B-UD-Q6_K_XL": {
          "name": "Qwen 3.6 27B"
        },
      }
    },
    "yescale-deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "YEScale Deepseek",
      "options": {
        "baseURL": "https://api.yescale.vip/v1",
      },
      "models": {
        "deepseek-v3.2": {
          "name": "Deepseek V3.2"
        },
        "deepseek-v3.2-thinking": {
          "name": "Deepseek V3.2 Thinking"
        }
      }
    },
    "yescale-normal": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "YEScale Normal",
      "options": {
        "baseURL": "https://api.yescale.vip/v1",
      },
      "models": {
        "glm-4.7": {
          "name": "GLM-4.7"
        },
        "kimi-k2-thinking": {
          "name": "Kimi K2"
        },
        "MiniMax-M2.7": {
          "name": "MiniMax M2.7"
        },
      }
    }
  },
  "permission": {
    "*": "ask",
    "task": {
      "*": "ask",
      "research": "allow",
    },
    "read": {
      "*": "ask",
      "~/Repo/*": "allow"
    },
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "find *": "allow",
      "find * -exec *": "deny",
      "git status *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "echo *": "allow",
      "wc *": "allow",
      "ls *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "tree *": "allow",
      "file *": "allow",
    },
    "external_directory": {
      "*": "ask",
      "~/Repo/*": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "skill": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "kubernetes_pods_list_*": "allow",
    "kubernetes_pods_get": "allow",
    "kubernetes_pods_log": "allow",
    "kubernetes_resources_list": "allow",
    "kubernetes_resources_get": "allow",
    "kubernetes_namespaces_list": "allow",
    "kubernetes_configuration_contexts_list": "allow",
    "excalidraw_*": "allow",
  },
  "mcp": {
    "kubernetes": {
      "type": "local",
      "command": [
        "uvx",
        "kubernetes-mcp-server@latest",
        "--read-only"
      ],
      "enabled": false,
      "environment": {}
    },
    "excalidraw": {
      "type": "remote",
      "url": "https://mcp.excalidraw.com",
      "enabled": false
    },
  }
}
